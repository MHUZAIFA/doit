# Required
MONGODB_URI=mongodb://127.0.0.1:27017/doit
MONGODB_DB=doit
AUTH_SECRET=replace-with-at-least-16-random-bytes-hex-or-string

# AI (at least one for NLP / chat summaries)
# xAI (Grok): https://console.x.ai — keys usually start with xai-
XAI_API_KEY=
XAI_MODEL=grok-4-1-fast-non-reasoning
# Groq: https://console.groq.com — keys start with gsk_ (do not use gsk_ as XAI_API_KEY; use this var or we auto-detect gsk_ in XAI_API_KEY)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Routing & maps (free stack: OSM + ORS — https://openrouteservice.org/dev/#/signup )
OPENROUTESERVICE_API_KEY=
# Nominatim policy: identify your app ( https://operations.osmfoundation.org/policies/nominatim/ )
NOMINATIM_USER_AGENT=YourAppName/1.0 (contact@example.com)

# Optional legacy Google APIs (not used by the OSM map page)
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Weather (scheduling heuristics)
OPENWEATHER_API_KEY=

# Optional: 32-byte hex (64 chars) for AES-GCM title encryption when privacy mode is on
TASK_ENCRYPTION_KEY=
