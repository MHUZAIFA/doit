# Required
MONGODB_URI=mongodb://127.0.0.1:27017/doit
MONGODB_DB=doit
AUTH_SECRET=replace-with-at-least-16-random-bytes-hex-or-string

# AI (at least one for NLP / chat summaries)
XAI_API_KEY=
XAI_MODEL=grok-2-latest
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Maps (server: Distance Matrix, Directions, Places)
GOOGLE_MAPS_API_KEY=

# Maps (client: optional embed — restrict key by HTTP referrer in Google Cloud)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Weather (scheduling heuristics)
OPENWEATHER_API_KEY=

# Optional: 32-byte hex (64 chars) for AES-GCM title encryption when privacy mode is on
TASK_ENCRYPTION_KEY=
